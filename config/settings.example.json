    "ppo_total_steps": 50000,
    "ppo_total_steps_dynamic": 0,
    "ppo_n_steps": 512,
    "ppo_batch_size": 64,
    "ppo_learning_rate": 3e-4,
    "ppo_gamma": 0.99,
