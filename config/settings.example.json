  "dynamic": {
    "num_slots": 4,
    "slot_hours": 1.0,
    "switch_time_hours": 0.0
  },
  "speed": {
    "num_envs": 1,
    "device": "auto",
    "imitation_loss_target": 0.05
  },
  "reward": {
    "achievement_weight": 1.0,
    "switch_penalty": 0.02
  },
  "infer": {
    "dump_snapshot_json": false,
    "snapshot_dir": "artifacts/inference/snapshots",
    "use_snapshot_on_read": true,
    "horizon_hours": 1.0,
    "hours_per_day": 24.0,
    "write_report_html": true,
    "write_gantt_html": true,
    "report_dir": "artifacts/reports"
  },
  "virtual_eqp": {
    "gantt_slots": 24,
    "slot_hours": 1.0
  },
  "benchmark": {
    "dataset_root": "benchmarks",
    "report_path": "artifacts/reports/benchmark.html",
    "summary_md": "MODEL_BENCHMARK.md"
  },
  "tool_groups": {
    "G001": ["9C/92", "9C/102"],
